# ══════════════════════════════════════════════
# PostAllTon SaaS — Variáveis de Ambiente
# ══════════════════════════════════════════════

PORT=3001
APP_URL=https://sua-api.up.railway.app
FRONTEND_URL=https://postallton3.vercel.app

# ── JWT ───────────────────────────────────────
JWT_SECRET=coloque_uma_string_aleatoria_longa_aqui_minimo_32_caracteres
JWT_EXPIRES_IN=7d

# ── PostgreSQL ────────────────────────────────
# Railway fornece automaticamente quando você adiciona o plugin PostgreSQL
DATABASE_URL=postgresql://usuario:senha@host:5432/railway

# ── Google OAuth ──────────────────────────────
# Obter em: console.cloud.google.com → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=seu_google_client_id
GOOGLE_CLIENT_SECRET=seu_google_client_secret

# ── Stripe ────────────────────────────────────
# Obter em: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# IDs dos produtos criados no Stripe Dashboard
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BASIC_LIFETIME=price_...
STRIPE_PRICE_PRO_LIFETIME=price_...
STRIPE_PRICE_BUSINESS_LIFETIME=price_...

# ── Mercado Pago ──────────────────────────────
# Obter em: mercadopago.com.br → Desenvolvedores → Credenciais
MP_ACCESS_TOKEN=APP_USR-...
MP_WEBHOOK_SECRET=seu_webhook_secret

# ── Redes Sociais OAuth (por cliente) ─────────
# Meta (Instagram + Facebook + Threads)
META_APP_ID=seu_app_id
META_APP_SECRET=seu_app_secret
# TikTok
TIKTOK_CLIENT_KEY=seu_client_key
TIKTOK_CLIENT_SECRET=seu_client_secret
# LinkedIn
LINKEDIN_CLIENT_ID=seu_client_id
LINKEDIN_CLIENT_SECRET=seu_client_secret
# Twitter
TWITTER_API_KEY=sua_api_key
TWITTER_API_SECRET=seu_api_secret
# Google (YouTube)
YOUTUBE_CLIENT_ID=seu_client_id
YOUTUBE_CLIENT_SECRET=seu_client_secret
# Pinterest
PINTEREST_APP_ID=seu_app_id
PINTEREST_APP_SECRET=seu_app_secret
# Reddit
REDDIT_CLIENT_ID=seu_client_id
REDDIT_CLIENT_SECRET=seu_client_secret
